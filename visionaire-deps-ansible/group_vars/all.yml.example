# ============================================
# Contoh group_vars/all.yml — visionaire-deps-ansible
# Salin file ini tanpa .example lalu isi credential asli
# ============================================

ansible_user: "your_ssh_user"
ansible_ssh_pass: "YOUR_SSH_PASSWORD"
# ansible_ssh_private_key_file: "~/.ssh/id_rsa"   # kalau pakai SSH key, uncomment ini & hapus ansible_ssh_pass
ansible_become_pass: "YOUR_SUDO_PASSWORD"
